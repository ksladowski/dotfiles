	\end{equation}
	
	\begin{equation}
	    B = \left(B_{0x}\hat{x} + B_{0y}\hat{y}\right)e^{i(kz-\omega t)}
	\end{equation}
	
	\paragraph{}
	The z component of B and E is zero, as shown in lecture
	
	\begin{equation}
	    \nabla\times E = \frac{-\partial B}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla\times E = \hat{x}\left(-\frac{\partial}{\partial z}E_{0y}e^{i(kz-\omega t)}\right)
	-\hat{y}\left(-\frac{\partial}{\partial z}E_{0x}e^{i(kz-\omega t)}\right)
	\end{equation}
	
	\begin{equation}
