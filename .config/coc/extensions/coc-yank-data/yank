	    - \hat{y}\left(\frac{\partial}{\partial x}E_{0z}e^{i(kr-\omega t)} - \frac{\partial}{\partial z} E_{0x}e^{i(kr-\omega t)}\right)
	    + \hat{z}\left(\frac{\partial}{\partial x}E_{0y}e^{i(kr-\omega t)} - \frac{\partial}{\partial y} E_{0x}e^{i(kr-\omega t)}\right)
	\end{dmath}
	
	\begin{dmath}
	    \nabla \times E = \hat{x}\left(ikE_{0z}e^{i(kr-\omega t)} - ikE_{0y}e^{i(kr-\omega t)}\right)
	    - \hat{y}\left(ikE_{0z}e^{i(kr-\omega t)} - ikE_{0x}e^{i(kr-\omega t)}\right)
	    + \hat{z}\left(ikE_{0y}e^{i(kr-\omega t)} - ikE_{0x}e^{i(kr-\omega t)}\right)
	\end{dmath}
	
	\begin{dmath}
	    ik \times E = \hat{x}\left(ikE_{0z}e^{i(kr-\omega t)} - ikE_{0y}e^{i(kr-\omega t)}\right)
	    - \hat{y}\left(ikE_{0z}e^{i(kr-\omega t)} - ikE_{0x}e^{i(kr-\omega t)}\right)
	    + \hat{z}\left(ikE_{0y}e^{i(kr-\omega t)} - ikE_{0x}e^{i(kr-\omega t)}\right)
	\end{dmath}
	
	\begin{equation} 
