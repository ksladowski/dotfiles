	\begin{equation}
	    \nabla \times H = J + \frac{\partial D}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot \left( \nabla \times H \right) = \nabla \cdot J + \frac{\partial\left(\nabla\cdot D \right)}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot J + \frac{\partial\left(\nabla\cdot D \right)}{\partial t} = 0
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot D = \rho
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot J + \frac{\partial \rho}{\partial t} = 0
	\end{equation}
	
	\paragraph{}
	So, the relationship between the current density and the charge 
	density can be expressed as:
	
	\begin{equation}
	    \nabla \cdot J = - \frac{\partial \rho}{\partial t}
	\end{equation}
	
	
	\section{Problem 2}
	\subsection{a}
	
	\begin{equation}
	    \nabla \times B = \mu_0 J
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot \left( \nabla \times B \right) =  \nabla \cdot \mu_0 J
	\end{equation}
	
	\paragraph{}
	As in problem 1, the divergence of a curl is zero, and we proved the divergence of J such that:
	
	\begin{equation}
	    \nabla \times B = - \mu_0 \frac{\partial \rho}{\partial t}
	\end{equation}
	
	\paragraph{}
	However, this is not true for a non steady current, so this law cannot be physically possible.
	
	\subsection{b}
	
	\begin{equation}
	    \nabla \times B = - \mu_0 \frac{\partial \rho}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla \times B = \mu_0 \left( \nabla \cdot J \right)
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot J = -\frac{\partial\rho}{\partial t} = -\frac{\partial}{\partial t} \left(\epsilon_0\nabla\cdot E\right) = -\nabla \cdot \left(\epsilon_0\frac{\partial E}{\partial t}\right)
	\end{equation}
	
	\begin{equation}
	    \nabla \times B = \mu_0 \left( J + \epsilon_0 \frac{\partial E}{\partial t} \right)
	\end{equation}
	
	\begin{equation}
	    \nabla \times B = \mu_0 J + \mu_0 \epsilon_0 \frac{\partial E}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla \mu_0 J = -\nabla \mu_0\epsilon_0\frac{\partial E}{\partial t}
	\end{equation}
	
	\begin{equation}
	    \nabla \cdot \left(\nabla\times B\right) = 0
	\end{equation}
	
	
	\section{Problem 3}
	\subsection{a}
	
	\begin{dmath}
