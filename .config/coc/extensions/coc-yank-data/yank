	-\hat{y}\left(-kE_{0x}e^{i(kz-\omega t)}\right)
	\end{equation}
	
	\begin{equation}
	    \nabla\times E = -kE_{0y}e^{i(kz-\omega t)} + kE_{0x}e^{i(kz-\omega t)}
	\end{equation}
	
	\begin{equation}
	    \frac{-\partial B}{\partial t} = \frac{-\partial}{\partial t}B_{0x}e^{i(kz-\omega t)}\hat{x} + \frac{-\partial}{\partial t}B_{0y}e^{i(kz-\omega t)}\hat{y}
	\end{equation}
	
	\begin{equation}
