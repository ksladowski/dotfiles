	\end{equation}
	
	\begin{equation}
	-kE_{0y}e^{i(kz-\omega t)} + kE_{0x}e^{i(kz-\omega t)}= \omega B_{0x}e^{i(kz-\omega t)}\hat{x} + \omega B_{0y}e^{i(kz-\omega t)}\hat{y}
	\end{equation}
	
	\begin{equation}
	    -kE_{0x} + kE_{0y} = \omega B_{0x} + \omega B_{0y}
	\end{equation}
	
