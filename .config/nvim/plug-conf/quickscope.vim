let g:qs_highlight_on_keys = ['f', 'F', 't', 'T']

highlight QuickScopePrimary guifg='#ebcb8b' gui=underline ctermfg=155 cterm=underline
highlight QuickScopeSecondary guifg='#b48ead' gui=underline ctermfg=81 cterm=underline

let g:qs_max_chars=150
